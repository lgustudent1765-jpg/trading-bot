# ============================================================
# .env.test.example — Test environment variable template
# ============================================================
# Copy to .env.test and fill in values before running tests.
# These values are used by the test suite (pytest) and CI/CD.
#
# Usage:
#   cp .env.test.example .env.test
#   pytest tests/e2e/
#
# All credentials here are placeholders — never use real credentials
# in the test environment.
# ============================================================

# ---- Runtime mode (always "paper" in tests) ----
MODE=paper

# ---- Market data provider (mock for tests) ----
ALGO_SCREENER_PROVIDER=mock
ALGO_SCREENER_TOP_N=5
ALGO_SCREENER_POLL_INTERVAL_SECONDS=0.1
ALGO_SCREENER_MARKET_HOURS_ONLY=false

# ---- FMP API (leave blank for mock provider) ----
FMP_API_KEY=test-placeholder-key

# ---- Broker (always mock in tests) ----
BROKER=mock

# ---- Webull credentials (not used in tests — leave blank) ----
WEBULL_DEVICE_ID=
WEBULL_ACCESS_TOKEN=
WEBULL_REFRESH_TOKEN=
WEBULL_TRADE_TOKEN=
WEBULL_ACCOUNT_ID=

# ---- Robinhood credentials (not used in tests — leave blank) ----
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_CODE=

# ---- Logging ----
LOG_LEVEL=WARNING
# Set to true for JSON-structured logs in CI
LOG_JSON_FORMAT=false
LOG_FILE=

# ---- API Server ----
API_PORT=18081
ALGO_API_SERVER_HOST=127.0.0.1

# ---- Risk management ----
ALGO_RISK_MAX_POSITION_PCT=0.05
ALGO_RISK_MAX_OPEN_POSITIONS=5
ALGO_RISK_PDT_EQUITY_THRESHOLD=25000
ALGO_RISK_STOP_LOSS_ATR_MULT=1.5
ALGO_RISK_TAKE_PROFIT_ATR_MULT=3.0

# ---- Options filter ----
ALGO_OPTIONS_FILTER_MIN_VOLUME=100
ALGO_OPTIONS_FILTER_MIN_OPEN_INTEREST=500
ALGO_OPTIONS_FILTER_MAX_SPREAD_PCT=0.10
ALGO_OPTIONS_FILTER_MAX_DTE=30
ALGO_OPTIONS_FILTER_MIN_DTE=1
ALGO_OPTIONS_FILTER_MAX_OTM_PCT=0.15

# ---- Indicators ----
ALGO_INDICATORS_RSI_PERIOD=14
ALGO_INDICATORS_RSI_OVERBOUGHT=70
ALGO_INDICATORS_RSI_OVERSOLD=30
ALGO_INDICATORS_MACD_FAST=12
ALGO_INDICATORS_MACD_SLOW=26
ALGO_INDICATORS_MACD_SIGNAL=9
ALGO_INDICATORS_ATR_PERIOD=14
ALGO_INDICATORS_LOOKBACK_BARS=50
ALGO_INDICATORS_SIGNAL_COOLDOWN_MINUTES=30

# ---- Notifications (disabled in tests) ----
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_USER=
NOTIFY_EMAIL_PASS=
NOTIFY_EMAIL_RECIPIENT=
NOTIFY_WEBHOOK_ENABLED=false
NOTIFY_WEBHOOK_URL=
