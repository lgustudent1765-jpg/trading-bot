# Copy this file to .env.local and fill in values.
#
# Backend API base URL — used by BOTH:
#   • Next.js server-side proxy rewrites  (API calls from browser go through Next)
#   • Client-side WebSocket connection    (derived automatically: http→ws)
#
# Point this at wherever your algo-trade backend is running.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: override the server-side rewrite target independently.
# Defaults to NEXT_PUBLIC_API_URL when not set.
# ALGO_API_URL=http://localhost:8080
