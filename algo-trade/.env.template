# file: .env.template
# ============================================================
# Environment Variables Template
# ============================================================
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use a secrets manager (e.g., AWS Secrets Manager,
# HashiCorp Vault, or Hostinger environment variables).
# ============================================================

# ---- Operating mode ----------------------------------------
MODE=paper                         # paper | manual | automated

# ---- FMP API credentials -----------------------------------
# [CRITICAL] Required for live screener. Get a free key at:
# https://financialmodelingprep.com/
FMP_API_KEY=your_fmp_api_key_here

# ---- Webull credentials (only needed when broker=webull) ---
# [CRITICAL] Never share these values. Rotate regularly.
WEBULL_DEVICE_ID=
WEBULL_ACCESS_TOKEN=
WEBULL_REFRESH_TOKEN=
WEBULL_TRADE_TOKEN=
WEBULL_ACCOUNT_ID=

# ---- Logging -----------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=                          # Leave empty for stdout; set path for file

# ---- API server --------------------------------------------
API_PORT=8080

# ---- Configuration override --------------------------------
CONFIG_PATH=config.yaml

# ---- Optional environment overrides using ALGO_ prefix -----
# ALGO_SCREENER_TOP_N=15
# ALGO_OPTIONS_FILTER_MIN_VOLUME=200
# ALGO_RISK_MAX_POSITION_PCT=0.03
