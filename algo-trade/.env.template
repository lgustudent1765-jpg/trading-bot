
# file: .env.template
# Copy to .env and fill in values. Never commit .env to git.
# This file is auto-loaded by the application on startup.

# ---- Mode --------------------------------------------------
MODE=paper                        # paper | manual | automated

# ---- Market data -------------------------------------------
ALGO_SCREENER_PROVIDER=yahoo      # yahoo (free) | fmp (paid) | mock (testing)
ALGO_SCREENER_POLL_INTERVAL_SECONDS=60

# ---- FMP (only needed if provider=fmp) ---------------------
FMP_API_KEY=

# ---- Broker ------------------------------------------------
BROKER=mock                       # mock | webull
WEBULL_DEVICE_ID=
WEBULL_ACCESS_TOKEN=
WEBULL_REFRESH_TOKEN=
WEBULL_TRADE_TOKEN=
WEBULL_ACCOUNT_ID=

# ---- Logging -----------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/algo-trade.log

# ---- API server --------------------------------------------
API_PORT=8080

# ---- Email alerts (optional) -------------------------------
# Gmail: use an App Password, not your account password.
# Google Account -> Security -> 2-Step Verification -> App passwords
NOTIFY_EMAIL_USER=
NOTIFY_EMAIL_PASS=
# NOTIFY_EMAIL_RECIPIENT defaults to NOTIFY_EMAIL_USER if not set

# ---- Webhook alerts (optional) ----------------------------
# Discord: Server Settings -> Integrations -> Webhooks -> Copy URL
# Slack:   App -> Incoming Webhooks -> Add -> Copy URL
NOTIFY_WEBHOOK_URL=
